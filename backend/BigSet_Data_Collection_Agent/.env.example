# Tinyfish (Search + Fetch)
TINYFISH_API_KEY=

# OpenRouter (LLM orchestration)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
# Optional. Leave unset for Gemini/reasoning models (OpenRouter rejects temperature).
# OPENROUTER_TEMPERATURE=0.2
OPENROUTER_SITE_URL=https://github.com/MMeteorL/BigSet_Data_Collection_Agent
OPENROUTER_APP_NAME=BigSet Data Collection Agent

# v0.1 pipeline limits (optional overrides)
MAX_SEARCH_QUERIES=6
MAX_RESULTS_PER_QUERY=5
MAX_URLS_TO_FETCH=20
MAX_PAGE_CHARS=12000
EXTRACTION_CONCURRENCY=3

# v0.2 search-repair loop
ENABLE_REPAIR_LOOP=true
MAX_REPAIR_LOOPS=3
ENABLE_WORKFLOW_MEMORY=true
MAX_REPAIR_QUERIES=4
MAX_REPAIR_RESULTS_PER_QUERY=5
MAX_REPAIR_URLS_TO_FETCH=10
MAX_REPAIR_SEARCH_PAGINATION_QUERIES=2
MAX_SEARCH_PAGE=10
ENABLE_REPAIR_LINK_FOLLOW=true
MAX_REPAIR_LINK_URLS=8
MAX_LINKS_PER_SOURCE_PAGE=3

# v0.3 source triage + Tinyfish Agent
ENABLE_TRIAGE=true
ENABLE_TINYFISH_AGENT=true
MAX_AGENT_RUNS_PER_PHASE=5
AGENT_CONCURRENCY=2
# Async agent: queue all runs, then poll in parallel
AGENT_QUEUE_CONCURRENCY=10
AGENT_POLL_CONCURRENCY=10
AGENT_POLL_INTERVAL_MS=3000
AGENT_POLL_TIMEOUT_MS=1200000
TRIAGE_CONCURRENCY=5

# v0.4 parallel workers + rate limits
SEARCH_CONCURRENCY=4
FETCH_CONCURRENCY=4
FETCH_BATCH_SIZE=10
MAX_CONCURRENT_PER_DOMAIN=2
MAX_RETRIES=2
RETRY_BASE_DELAY_MS=1000
OPENROUTER_RPM=60
TINYFISH_SEARCH_RPM=30
TINYFISH_FETCH_RPM=30
TINYFISH_AGENT_RPM=10

# v1.0 data quality & confidence
ENABLE_QUALITY_SCORING=true
QUALITY_LOW_CONFIDENCE_THRESHOLD=0.55
QUALITY_REVIEW_THRESHOLD=0.75
QUALITY_SOURCE_CONFIDENCE_THRESHOLD=0.5
QUALITY_EXTRACTION_CONFIDENCE_THRESHOLD=0.6

# v1.3 selective results + recurring refresh (docs/v13-selective-results-and-refresh.md)
ENABLE_SELECTIVE_RESULTS=true

# v1.2 follow-up repair (pagination + outbound links — docs/v12-follow-up-repair.md)
MAX_REPAIR_LOOPS=1
ENABLE_WORKFLOW_MEMORY=true
MAX_REPAIR_SEARCH_PAGINATION_QUERIES=2
MAX_SEARCH_PAGE=10
ENABLE_REPAIR_LINK_FOLLOW=true
MAX_REPAIR_LINK_URLS=8
MAX_LINKS_PER_SOURCE_PAGE=3
