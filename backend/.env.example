CLIENT_ORIGIN=http://localhost:3500
CONVEX_URL=http://localhost:3210
PORT=3501

# Required once the backend starts writing rows via internal Convex mutations.
# Generate with: docker compose exec convex ./generate_admin_key.sh
CONVEX_SELF_HOSTED_ADMIN_KEY=

# Required once any user-facing protected route is added.
# Same value as the frontend's CLERK_SECRET_KEY.
CLERK_SECRET_KEY=

# OpenRouter — schema-inference CLI (npm run infer-schema) and collection pipeline LLM
# Generate at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Dataset agent runtime (ai-sdk | collection | deterministic)
DATASET_AGENT_RUNTIME=ai-sdk
DATASET_AGENT_MODEL=openai/gpt-5.4
DATASET_AGENT_MAX_STEPS=8

# Collection pipeline (DATASET_AGENT_RUNTIME=collection)
COLLECTION_AGENT_RUNTIME=
COLLECTION_AGENT_TARGET_ROWS=8
COLLECTION_AGENT_ENABLE_REPAIR=false
COLLECTION_AGENT_ENABLE_TRIAGE=true
COLLECTION_AGENT_ENABLE_AGENT=true
TINYFISH_API_KEY=

# v0.1 pipeline limits (optional overrides)
MAX_SEARCH_QUERIES=5
MAX_RESULTS_PER_QUERY=10
MAX_URLS_TO_FETCH=20
MAX_PAGE_CHARS=25000
EXTRACTION_CONCURRENCY=10

# v0.2 search-repair loop
ENABLE_REPAIR_LOOP=true
MAX_REPAIR_QUERIES=10
MAX_REPAIR_RESULTS_PER_QUERY=5
MAX_REPAIR_URLS_TO_FETCH=20

# v0.3 source triage + Tinyfish Agent
ENABLE_TRIAGE=true
ENABLE_TINYFISH_AGENT=true
MAX_AGENT_RUNS_PER_PHASE=5
AGENT_CONCURRENCY=5
TRIAGE_CONCURRENCY=10

# v0.4 parallel workers + rate limits
SEARCH_CONCURRENCY=4
FETCH_CONCURRENCY=4
FETCH_BATCH_SIZE=10
MAX_CONCURRENT_PER_DOMAIN=2
MAX_RETRIES=2
RETRY_BASE_DELAY_MS=1000
OPENROUTER_RPM=60
TINYFISH_SEARCH_RPM=30
TINYFISH_FETCH_RPM=30
TINYFISH_AGENT_RPM=10

# v1.0 data quality & confidence
ENABLE_QUALITY_SCORING=true
QUALITY_LOW_CONFIDENCE_THRESHOLD=0.55
QUALITY_REVIEW_THRESHOLD=0.75
QUALITY_SOURCE_CONFIDENCE_THRESHOLD=0.4
QUALITY_EXTRACTION_CONFIDENCE_THRESHOLD=0.4

# v1.1 self learning repair loop
MAX_REPAIR_LOOPS=1
ENABLE_WORKFLOW_MEMORY=true

# v1.2 self learning follow-up repair loop
MAX_REPAIR_SEARCH_PAGINATION_QUERIES=2
MAX_SEARCH_PAGE=5
ENABLE_REPAIR_LINK_FOLLOW=true
MAX_REPAIR_LINK_URLS=8
MAX_LINKS_PER_SOURCE_PAGE=3

# Tinyfish Agent async polling
AGENT_QUEUE_CONCURRENCY=10
AGENT_POLL_CONCURRENCY=10
AGENT_POLL_INTERVAL_MS=3000
AGENT_POLL_TIMEOUT_MS=1200000
